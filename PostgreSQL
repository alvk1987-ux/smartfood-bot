async def show_stats_period(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Показ статистики за период"""
    query = update.callback_query
    await query.answer()
    
    user_id = query.from_user.id
    period = query.data.replace("stats_", "")
    
    conn = get_db_connection()
    cur = conn.cursor()
    
    if period == "today":
        date_filter = "meal_date = CURRENT_DATE"
        period_name = "Сегодня"
    elif period == "week":
        date_filter = "meal_date >= CURRENT_DATE - INTERVAL '7 days'"
        period_name = "За неделю"
    elif period == "month":
        date_filter = "meal_date >= CURRENT_DATE - INTERVAL '30 days'"
        period_name = "За месяц"
    else:
        # Показываем цели
        await show_goals(query, context)
        return
    
    # Получаем статистику
    cur.execute(f"""
        SELECT 
            COUNT(DISTINCT meal_date) as days,
            COUNT(*) as total_meals,
            AVG(calories) as avg_calories,
            SUM(calories) as total_calories,
            SUM(protein) as total_protein,
            SUM(fats) as total_fats,
            SUM(carbs) as total_carbs,
            
            -- Статистика по приемам пищи
            COUNT(*) FILTER (WHERE meal_type = 'breakfast') as breakfasts,
            COUNT(*) FILTER (WHERE meal_type = 'lunch') as lunches,
            COUNT(*) FILTER (WHERE meal_type = 'dinner') as dinners,
            COUNT(*) FILTER (WHERE meal_type = 'snack') as snacks
        FROM meals
        WHERE user_id = %s AND {date_filter}
    """, (user_id,))
    
    stats = cur.fetchone()
    
    if not stats or stats['total_meals'] == 0:
        await query.edit_message_text(
            f"📊 {period_name}: нет данных\n\n"
            f"Начните записывать приемы пищи!",
            reply_markup=get_main_keyboard()
        )
        return
    
    days = stats['days'] or 1
    avg_per_day_cal = stats['total_calories'] / days
    avg_per_day_prot = stats['total_protein'] / days
    avg_per_day_fats = stats['total_fats'] / days  
    avg_per_day_carbs = stats['total_carbs'] / days
    
    response = f"""
📊 Статистика: {period_name}

📅 Дней с записями: {stats['days']}
🍽 Всего приемов пищи: {stats['total_meals']}

📈 В среднем в день:
🔥 Калории: {avg_per_day_cal:.0f} ккал
🥩 Белки: {avg_per_day_prot:.1f} г
🥑 Жиры: {avg_per_day_fats:.1f} г
🍞 Углеводы: {avg_per_day_carbs:.1f} г

📝 Приемы пищи:
🌅 Завтраков: {stats['breakfasts']}
🍽 Обедов: {stats['lunches']}
🌙 Ужинов: {stats['dinners']}
🍎 Перекусов: {stats['snacks']}

💡 Рекомендация: {'Отличная регулярность!' if stats['breakfasts'] >= days * 0.8 else 'Не пропускайте завтраки!'}
"""
    
    await query.edit_message_text(response)
    
    cur.close()
    conn.close()

