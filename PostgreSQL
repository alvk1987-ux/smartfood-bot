# === АВТОМАТИЧЕСКИЕ ОТЧЕТЫ ===  
async def send_daily_report(context: ContextTypes.DEFAULT_TYPE):
    """Отправка ежедневного отчета"""
    job = context.job
    user_id = job.data['user_id']
    
    conn = get_db_connection()
    cur = conn.cursor()
    
    # Получаем статистику за день
    cur.execute("""
        SELECT 
            COUNT(*) as meals_count,
            SUM(calories) as total_calories,
            SUM(protein) as total_protein,
            SUM(fats) as total_fats,
            SUM(carbs) as total_carbs
        FROM meals
        WHERE user_id = %s AND meal_date = CURRENT_DATE
    """, (user_id,))
    
    stats = cur.fetchone()
    
    if stats and stats['meals_count'] > 0:
        # Получаем целевые показатели
        cur.execute("""
            SELECT target_calories, target_protein, target_fats, target_carbs
            FROM users
            WHERE user_id = %s
        """, (user_id,))
        
        targets = cur.fetchone()
        
        report = f"""
📊 Итоги дня:

🍽 Приемов пищи: {stats['meals_count']}

📈 Потреблено:
🔥 Калории: {stats['total_calories']:.0f} ккал
🥩 Белки: {stats['total_protein']:.1f} г
🥑 Жиры: {stats['total_fats']:.1f} г
🍞 Углеводы: {stats['total_carbs']:.1f} г
"""
        
        if targets:
            cal_percent = (stats['total_calories'] / targets['target_calories']) * 100 if targets['target_calories'] else 0
            
            report += f"""
🎯 Выполнение целей: {cal_percent:.0f}%

{'✅ Отличный день!' if cal_percent >= 90 and cal_percent <= 110 else '💪 Продолжайте в том же духе!'}
"""
        
        await context.bot.send_message(
            chat_id=user_id,
            text=report,
            reply_markup=get_main_keyboard()
        )
    
    cur.close()
    conn.close()

# === ОБНОВЛЕННАЯ ГЛАВНАЯ ФУНКЦИЯ ===
def main():
    """Главная функция с расширенным функционалом"""
    token = os.getenv("TELEGRAM_BOT_TOKEN")
    if not token:
        logger.error("TELEGRAM_BOT_TOKEN not found!")
        return
    
    logger.info("Starting SmartFood AI Bot 2.0...")
    
    app = Application.builder().token(token).build()
    
    # Обработчик записи приема пищи
    meal_conv = ConversationHandler(
        entry_points=[MessageHandler(filters.Regex("^📝 Записать прием пищи$"), record_meal_start)],
        states={
            WAITING_MEAL_RECORD: [
                CallbackQueryHandler(meal_type_selected, pattern="^meal_"),
                MessageHandler(filters.TEXT & ~filters.COMMAND, process_meal_record)
            ]
        },
        fallbacks=[CommandHandler("cancel", cancel)]
    )
    
    # Добавляем обработчики
    app.add_handler(CommandHandler("start", start))
    app.add_handler(meal_conv)
    app.add_handler(MessageHandler(filters.Regex("^📊 Моя статистика$"), show_statistics))
    app.add_handler(MessageHandler(filters.Regex("^⏰ Настроить напоминания$"), setup_reminders))
    app.add_handler(CallbackQueryHandler(show_stats_period, pattern="^stats_"))
    
    # ... остальные обработчики из предыдущей версии
    
    # Запуск
    logger.info("Bot started successfully with diary features!")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()
